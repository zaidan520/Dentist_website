---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen bg-white relative pt-24 md:pt-28">
    <div
      class="absolute inset-0 bg-gradient-to-b from-stone-50/60 via-white to-white pointer-events-none"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-64 md:h-80 bg-[url('https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_114355_752ba9e6-0942-4abb-9047-5d9bb16632e9.png&w=1280&q=85')] bg-cover bg-center opacity-[0.03] pointer-events-none"
    >
    </div>
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12 py-16 md:py-4 relative">
      <div class="text-center mb-16">
        <span
          class="text-xs font-extrabold text-neutral-400 uppercase tracking-widest"
          >Get In Touch</span
        >
        <h1
          class="text-4xl md:text-6xl font-bold text-black mt-4 leading-tight"
        >
          Contact Us
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <!-- Left: Info -->
        <div class="space-y-8">
          <div>
            <span
              class="text-[10px] font-extrabold text-neutral-400 uppercase tracking-widest block mb-1"
              >Address</span
            >
            <span class="text-sm font-semibold text-black">
              6000 Palisade Avenue, West New York, NJ 07093
            </span>
          </div>

          <div class="flex flex-col sm:flex-row gap-8">
            <div>
              <span
                class="text-[10px] font-extrabold text-neutral-400 uppercase tracking-widest block mb-1"
                >Phone</span
              >
              <a
                href="tel:+15550199"
                class="text-sm font-bold text-black hover:underline"
              >
                +1 (555) 0199
              </a>
            </div>
            <div>
              <span
                class="text-[10px] font-extrabold text-neutral-400 uppercase tracking-widest block mb-1"
                >Email</span
              >
              <a
                href="mailto:info@wnydentalhealth.com"
                class="text-sm font-bold text-black hover:underline"
              >
                info@wnydentalhealth.com
              </a>
            </div>
          </div>

          <div>
            <span
              class="text-[10px] font-extrabold text-neutral-400 uppercase tracking-widest block mb-2"
              >Business Hours</span
            >
            <ul class="text-xs text-neutral-600 space-y-2 font-semibold">
              <li
                class="flex justify-between border-b border-dashed border-neutral-100 pb-2 max-w-[240px]"
              >
                <span>Monday - Friday</span>
                <span class="text-black">8:00 AM - 6:00 PM</span>
              </li>
              <li
                class="flex justify-between border-b border-dashed border-neutral-100 pb-2 max-w-[240px]"
              >
                <span>Saturday</span>
                <span class="text-black">9:00 AM - 3:00 PM</span>
              </li>
              <li class="flex justify-between max-w-[240px] text-red-500">
                <span>Sunday</span>
                <span>Closed</span>
              </li>
            </ul>
          </div>

          <div class="rounded-2xl overflow-hidden h-56 md:h-64 shadow-sm">
            <iframe
              title="Google Map Location"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d12086.82869151528!2d-74.01509930438186!3d40.78712396349079!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25838cccdbe07%3A0x6b4ea39ef6791e84!2sWest%20New%20York%2C%20NJ!5e0!3m2!1sen!2sus!4v1687870000000!5m2!1sen!2sus"
              class="w-full h-full border-0"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

        <!-- Right: Form -->
        <div
          class="border-t border-neutral-100 pt-8 md:border-t-0 md:pt-0 md:border-l md:border-neutral-100 md:pl-12"
        >
          <h2
            class="text-sm font-extrabold text-black uppercase tracking-wider mb-6"
          >
            Send a Message
          </h2>
          <form id="contact-message-form" class="space-y-5">
            <div>
              <label
                class="block text-xs font-semibold text-neutral-500 mb-1.5"
                for="contact-name">Full Name</label
              >
              <input
                type="text"
                id="contact-name"
                required
                class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
                placeholder="Your Name"
              />
            </div>
            <div>
              <label
                class="block text-xs font-semibold text-neutral-500 mb-1.5"
                for="contact-email">Email Address</label
              >
              <input
                type="email"
                id="contact-email"
                required
                class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label
                class="block text-xs font-semibold text-neutral-500 mb-1.5"
                for="contact-message">Message</label
              >
              <textarea
                id="contact-message"
                rows="5"
                required
                class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white resize-none"
                placeholder="How can we help you?"></textarea>
            </div>
            <button
              type="submit"
              class="w-full py-3.5 bg-black text-white text-xs font-bold rounded-lg hover:bg-neutral-800 transition-colors cursor-pointer shadow-md"
            >
              Submit Message
            </button>
            <div
              id="contact-success-alert"
              class="hidden bg-green-50 text-green-800 text-xs p-4 rounded-lg border border-green-200"
            >
              Message sent successfully! Our staff will contact you shortly.
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  function setupContactForm() {
    const contactForm = document.getElementById("contact-message-form");
    const successAlert = document.getElementById("contact-success-alert");
    if (!contactForm) return;

    contactForm.addEventListener("submit", (e) => {
      e.preventDefault();
      successAlert?.classList.remove("hidden");
      contactForm.reset();
      setTimeout(() => {
        successAlert?.classList.add("hidden");
      }, 5000);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupContactForm);
  } else {
    setupContactForm();
  }
</script>
