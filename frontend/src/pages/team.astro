---
import Layout from "../layouts/Layout.astro";

const dentistTeam = [
  {
    name: "Dr. Eleanor Vance, DDS",
    qualification: "Columbia University College of Dental Medicine",
    specialization: "Chief Cosmetic Dentist & Aesthetic Reconstructions",
    experience: "15+ Years of Clinical Practice",
    certifications: [
      "American Academy of Cosmetic Dentistry (AACD)",
      "Int. Congress of Oral Implantologists",
    ],
    languages: ["English", "Spanish"],
    bio: "Dr. Eleanor Vance is a visionary in aesthetic dentistry, having crafted over 2,000 custom smile makeovers. She combines advanced porcelain veneer techniques with a meticulous eye for facial harmony, delivering natural, radiant smiles that build lifelong confidence.",
    photo:
      "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_115237_fc519057-6e87-4abf-999a-9610b8b085b4.png&w=400&q=80",
  },
  {
    name: "Dr. Marcus Thorne, DDS, PhD",
    qualification: "New York University College of Dentistry",
    specialization: "Senior Implantologist & Oral Surgery Specialist",
    experience: "12+ Years of Advanced Implant Surgery",
    certifications: [
      "Board Certified Oral Implantologist",
      "Fellow of the American Academy of Implant Dentistry (FAAID)",
    ],
    languages: ["English", "German"],
    bio: "Dr. Marcus Thorne is a leading specialist in computer-guided implant surgeries and immediate load restorations. With a doctorate in bone regeneration, he is highly trusted for painless, minimally invasive full-mouth reconstructions.",
    photo:
      "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_115253_c19ab167-8dd5-48b4-967d-b9f0d9d6e8fb.png&w=400&q=80",
  },
  {
    name: "Dr. Sarah Lin, DMD",
    qualification:
      "Boston University Henry M. Goldman School of Dental Medicine",
    specialization: "General Dentist & Endodontic Specialist",
    experience: "8+ Years of Family & Microscopic Dentistry",
    certifications: [
      "American Association of Endodontists",
      "Academy of General Dentistry (AGD)",
    ],
    languages: ["English", "Mandarin"],
    bio: "Dr. Sarah Lin specializes in microscopic endodontics (root canals) and preventive general care. Known for her exceptionally gentle and friendly touch, she excels at making complex procedures completely anxiety-free for patients of all ages.",
    photo:
      "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_114355_752ba9e6-0942-4abb-9047-5d9bb16632e9.png&w=400&q=80",
  },
];
---

<Layout>
  <main class="min-h-screen bg-white relative pt-24 md:pt-28">
    <div
      class="absolute inset-0 bg-gradient-to-b from-stone-50/60 via-white to-white pointer-events-none"
    >
    </div>
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-64 md:h-80 bg-[url('https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_114355_752ba9e6-0942-4abb-9047-5d9bb16632e9.png&w=1280&q=85')] bg-cover bg-center opacity-[0.03] pointer-events-none"
    >
    </div>
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12 py-16 md:py-4 relative">
      <div class="text-center mb-16">
        <span
          class="text-xs font-extrabold text-neutral-400 uppercase tracking-widest"
          >Specialists You Can Trust</span
        >
        <h1
          class="text-4xl md:text-6xl font-bold text-black mt-4 leading-tight"
        >
          Meet Our Experts
        </h1>
        <p
          class="text-neutral-500 text-sm md:text-base mt-4 max-w-2xl mx-auto leading-relaxed"
        >
          Our team of board-certified dentists brings decades of combined
          experience and a passion for exceptional patient care.
        </p>
      </div>

      <div class="space-y-16">
        {
          dentistTeam.map((member) => (
            <div class="flex flex-col md:flex-row gap-8 items-start">
              <div class="w-full md:w-40 h-52 md:h-56 rounded-2xl overflow-hidden shrink-0 shadow-md">
                <img
                  src={member.photo}
                  alt={member.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="flex-1">
                <h2 class="text-2xl md:text-3xl font-extrabold text-black">
                  {member.name}
                </h2>
                <p class="text-xs font-extrabold text-neutral-400 uppercase tracking-wider mt-1">
                  {member.specialization}
                </p>
                <p class="text-xs text-neutral-600 font-semibold mt-1">
                  {member.qualification}
                </p>
                <span class="inline-block bg-neutral-100 text-neutral-800 text-[10px] font-bold px-3 py-1 rounded-full mt-3">
                  {member.experience}
                </span>

                <p class="text-neutral-600 text-sm md:text-base leading-relaxed mt-6 mb-6">
                  {member.bio}
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <h3 class="text-[10px] font-extrabold text-black uppercase tracking-wider mb-2">
                      Certifications
                    </h3>
                    <ul class="space-y-1">
                      {member.certifications.map((cert) => (
                        <li class="text-xs text-neutral-600 flex items-center gap-1.5">
                          <span class="text-black">•</span> {cert}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h3 class="text-[10px] font-extrabold text-black uppercase tracking-wider mb-2">
                      Languages Spoken
                    </h3>
                    <p class="text-xs font-bold text-neutral-700">
                      {member.languages.join(", ")}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </main>
</Layout>
