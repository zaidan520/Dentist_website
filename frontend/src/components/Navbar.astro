---
interface Props {
  client?: Record<string, any>;
}

const { client } = Astro.props;

// When a client is present, every internal link gets prefixed with their
// slug so /joe-pizza/about, /joe-pizza/services etc. resolve correctly.
// On the main site (no client), links stay exactly as they were.
const base = client?.slug ? `/${client.slug}` : '';

const businessName: string = client?.business_name ?? 'Dental Health';
// Split into two stacked words the same way "Dental" / "Health" was split.
// If the name has 2+ words, use the first two; otherwise keep it on one line.
const nameParts = businessName.trim().split(/\s+/);
const nameLine1 = nameParts[0];
const nameLine2 = nameParts.length > 1 ? nameParts.slice(1).join(' ') : '';

const phone: string = client?.phone ?? '+1 (555) 0199';
const phoneHref = `tel:${(client?.phone ?? '+15550199').replace(/[^\d+]/g, '')}`;
---
<header id="main-navbar" class="fixed top-0 left-0 right-0 z-[101] px-4 md:px-8 lg:px-12 py-3 md:py-4 bg-white/80 backdrop-blur-md border-b border-neutral-100/50 flex items-center justify-between select-none transition-all duration-300">
  <!-- Logo -->
  <a href={base || '/'} class="flex flex-col group shrink-0" aria-label={`${businessName} Home`}>
    <div class="text-xl md:text-2xl font-extrabold uppercase tracking-tight leading-none text-black">
      <div>{nameLine1}</div>
      {nameLine2 && <div class="-mt-1.5 md:-mt-2">{nameLine2}</div>}
    </div>
    <span class="text-[8px] md:text-[9px] font-medium uppercase tracking-wider text-neutral-500 leading-none mt-1.5 md:mt-2">
      quality healthcare
    </span>
  </a>

  <!-- Desktop Nav Links (visible on md+) -->
  <nav class="hidden md:flex items-center gap-1 lg:gap-2" aria-label="Main Navigation">
    <a href={base || '/'} class="nav-link px-3 lg:px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-black rounded-full hover:bg-neutral-100 transition-all duration-200">Home</a>
    <a href={`${base}/services`} class="nav-link px-3 lg:px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-black rounded-full hover:bg-neutral-100 transition-all duration-200">Services</a>
    <a href={`${base}/about`} class="nav-link px-3 lg:px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-black rounded-full hover:bg-neutral-100 transition-all duration-200">About</a>
    <a href={`${base}/team`} class="nav-link px-3 lg:px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-black rounded-full hover:bg-neutral-100 transition-all duration-200">Our Team</a>
    <a href={`${base}/contact`} class="nav-link px-3 lg:px-4 py-2 text-sm font-semibold text-neutral-600 hover:text-black rounded-full hover:bg-neutral-100 transition-all duration-200">Contact</a>
  </nav>

  <!-- Desktop CTA + Emergency -->
  <div class="hidden md:flex items-center gap-4 shrink-0">
    <span class="text-xs font-semibold text-neutral-500 select-text hidden lg:inline">
      <a href={phoneHref} class="hover:text-black transition-colors">{phone}</a>
    </span>
    <button id="book-btn-nav" class="px-5 py-2.5 bg-black rounded-full text-white text-xs font-bold hover:bg-neutral-800 transition-colors duration-200 cursor-pointer shadow-sm">
      Book Appointment
    </button>
  </div>

  <!-- Mobile Hamburger -->
  <button id="hamburger-btn" class="md:hidden w-10 h-10 flex items-center justify-center relative z-50 cursor-pointer" aria-label="Toggle Menu">
    <span class="hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] -translate-y-2"></span>
    <span class="hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] opacity-100 scale-x-100"></span>
    <span class="hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] translate-y-2"></span>
  </button>
</header>

<!-- Mobile Menu Overlay (only on mobile) -->
<div id="menu-overlay" class="fixed inset-0 z-40 pointer-events-none select-none md:hidden">
  <!-- Backdrop -->
  <div id="menu-backdrop" class="absolute inset-0 bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]"></div>
  
  <!-- Panel -->
  <div id="menu-panel" class="absolute top-0 right-0 h-full w-[85%] max-w-sm bg-white shadow-2xl translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] flex flex-col">
    <div class="h-20 shrink-0"></div>
    
    <div class="flex-1 flex flex-col justify-center px-8 gap-1.5">
      <nav class="flex flex-col gap-3">
        <a href={base || '/'} class="menu-link text-4xl font-bold text-black hover:text-neutral-500 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]">Home</a>
        <a href={`${base}/services`} class="menu-link text-4xl font-bold text-black hover:text-neutral-500 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]">Services</a>
        <a href={`${base}/about`} class="menu-link text-4xl font-bold text-black hover:text-neutral-500 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]">About</a>
        <a href={`${base}/team`} class="menu-link text-4xl font-bold text-black hover:text-neutral-500 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]">Our Team</a>
        <a href={`${base}/contact`} class="menu-link text-4xl font-bold text-black hover:text-neutral-500 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]">Contact</a>
      </nav>
      
      <div id="menu-bottom" class="mt-8 pt-8 border-t border-neutral-200 opacity-0 translate-x-8 transition-all duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] shrink-0 select-text">
        <div class="text-sm font-semibold text-black mb-4">
          Emergency: <a href={phoneHref} class="hover:underline text-neutral-600">{phone}</a>
        </div>
        <button id="book-btn-menu" class="w-full px-6 py-4 bg-black rounded-full text-white text-sm font-semibold hover:bg-neutral-800 transition-colors duration-200 cursor-pointer">
          Book Appointment
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initNavbar() {
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const menuOverlay = document.getElementById('menu-overlay');
    const menuBackdrop = document.getElementById('menu-backdrop');
    const menuPanel = document.getElementById('menu-panel');
    const menuLinks = document.querySelectorAll('.menu-link');
    const menuBottom = document.getElementById('menu-bottom');
    const bookBtnMenu = document.getElementById('book-btn-menu');
    const bookBtnNav = document.getElementById('book-btn-nav');
    const lines = document.querySelectorAll('.hamburger-line');

    let isOpen = false;

    function toggleMenu(state) {
      isOpen = state !== undefined ? state : !isOpen;

      if (isOpen) {
        menuOverlay?.classList.remove('pointer-events-none');
        menuOverlay?.classList.add('pointer-events-auto');
        menuBackdrop?.classList.remove('opacity-0', 'pointer-events-none');
        menuBackdrop?.classList.add('opacity-100', 'pointer-events-auto');
        menuPanel?.classList.remove('translate-x-full');
        menuPanel?.classList.add('translate-x-0');
        document.body.style.overflow = 'hidden';

        if (lines[0]) lines[0].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] rotate-45 translate-y-0';
        if (lines[1]) lines[1].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] opacity-0 scale-x-0';
        if (lines[2]) lines[2].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] -rotate-45 translate-y-0';

        menuLinks.forEach((link, idx) => {
          setTimeout(() => {
            link.classList.remove('opacity-0', 'translate-x-8');
            link.classList.add('opacity-100', 'translate-x-0');
          }, 100 + idx * 60);
        });
        setTimeout(() => {
          menuBottom?.classList.remove('opacity-0', 'translate-x-8');
          menuBottom?.classList.add('opacity-100', 'translate-x-0');
        }, 100 + menuLinks.length * 60 + 50);
      } else {
        menuOverlay?.classList.remove('pointer-events-auto');
        menuOverlay?.classList.add('pointer-events-none');
        menuBackdrop?.classList.remove('opacity-100', 'pointer-events-auto');
        menuBackdrop?.classList.add('opacity-0', 'pointer-events-none');
        menuPanel?.classList.remove('translate-x-0');
        menuPanel?.classList.add('translate-x-full');
        document.body.style.overflow = '';

        if (lines[0]) lines[0].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] -translate-y-2';
        if (lines[1]) lines[1].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] opacity-100 scale-x-100';
        if (lines[2]) lines[2].className = 'hamburger-line absolute h-0.5 w-6 bg-black rounded-full transition-all duration-300 ease-[cubic-bezier(0.76,0,0.24,1)] translate-y-2';

        menuLinks.forEach((link) => {
          link.classList.add('opacity-0', 'translate-x-8');
          link.classList.remove('opacity-100', 'translate-x-0');
        });
        menuBottom?.classList.add('opacity-0', 'translate-x-8');
        menuBottom?.classList.remove('opacity-100', 'translate-x-0');
      }
    }

    hamburgerBtn?.addEventListener('click', () => toggleMenu());
    menuBackdrop?.addEventListener('click', () => toggleMenu(false));

    // Mobile menu links
    menuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        toggleMenu(false);
      });
    });

    // Book Appointment buttons
    bookBtnMenu?.addEventListener('click', () => {
      toggleMenu(false);
      setTimeout(() => {
        document.dispatchEvent(new CustomEvent('open-drawer', { detail: { target: 'booking' } }));
      }, 300);
    });

    bookBtnNav?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('open-drawer', { detail: { target: 'booking' } }));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavbar);
  } else {
    initNavbar();
  }
</script>