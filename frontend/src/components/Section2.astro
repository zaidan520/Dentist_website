---
interface Props {
  client?: {
    phone?: string;
    gallery_image?: string;
    services?: Array<{ name: string; num?: string; active?: boolean; key: string }>;
  };
}

const { client } = Astro.props;

const SECTION2_IMAGE =
  client?.gallery_image ??
  'https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_114219_414dfe80-f15c-4e25-bf52-b13721f4bd88.png&w=1280&q=85';

const phone = client?.phone ?? '+15550199';

const services =
  client?.services ?? [
    { name: 'Dental\nVeneers', num: '01', active: true,  key: 'veneers'   },
    { name: 'Dental\nCrowns',  num: '02', active: false, key: 'crowns'    },
    { name: 'Teeth\nWhitening',num: '03', active: false, key: 'whitening' },
    { name: 'Dental\nImplants',num: undefined, active: false, key: 'implants'  },
  ];
---

<section
  id="gallery"
  class="reveal-container min-h-screen md:h-screen w-full overflow-hidden flex flex-col pt-1.5 md:pt-2 px-3 md:px-5 pb-1.5 md:pb-2 gap-1.5 md:gap-2 select-none"
  data-focal-x-mobile="0.65"
  data-focal-x-desktop="0.8"
  data-bg-image={SECTION2_IMAGE}
>
  <div class="flex-1 min-h-0 grid grid-cols-1 md:grid-cols-2 grid-rows-[auto_auto_auto_auto] md:grid-rows-[1fr_1fr_0.8fr] gap-1.5 md:gap-2">

    <!-- Card 0 – Top Left -->
    <div
      class="reveal-item masked-card rounded-xl md:rounded-2xl overflow-hidden relative min-h-[160px] md:min-h-0"
      data-card-index="0"
    >
      <h2 class="absolute top-4 left-5 md:top-6 md:left-7 text-white md:text-black text-2xl md:text-3xl font-bold z-10">
        Smile Gallery
      </h2>
      <span class="absolute bottom-4 left-5 md:bottom-6 md:left-7 text-white md:text-black text-xs md:text-sm font-semibold z-10">
        Our cosmetic dental work
      </span>
    </div>

    <!-- Card 1 – Top Right (spans 2 rows on desktop) -->
    <div
      class="reveal-item masked-card md:row-span-2 rounded-xl md:rounded-2xl overflow-hidden relative min-h-[200px] md:min-h-0"
      data-card-index="1"
    >
      <div class="absolute bottom-16 left-5 md:bottom-20 md:left-7 text-white text-xs md:text-sm font-semibold leading-4 md:leading-5 z-10 max-w-[250px] md:max-w-xs select-text">
        If you want a gorgeous smile,<br />call us to ask about a smile makeover.
      </div>
      <a
        href={`tel:${phone}`}
        class="absolute bottom-4 right-4 md:bottom-6 md:right-6 px-5 py-3 md:px-8 md:py-5 bg-white rounded-full text-black text-base md:text-xl font-bold z-10 hover:scale-105 transition-transform duration-200 shadow-md flex items-center justify-center"
      >
        Call Us
      </a>
    </div>

    <!-- Card 2 – Bottom Left -->
    <div
      class="reveal-item masked-card rounded-xl md:rounded-2xl overflow-hidden relative min-h-[160px] md:min-h-0"
      data-card-index="2"
    >
      <h2 class="absolute top-4 left-5 md:top-6 md:left-7 text-white md:text-black text-[clamp(3rem,7vw,6rem)] font-bold leading-[0.9] z-10">
        Smile<br />makeover
      </h2>
    </div>

    <!-- Card 3 – Services Row -->
    <div
      class="reveal-item masked-card col-span-1 md:col-span-2 rounded-xl md:rounded-2xl overflow-hidden relative min-h-[200px] md:min-h-0"
      data-card-index="3"
    >
      <div class="absolute inset-0 z-10 flex flex-wrap md:flex-nowrap gap-1.5 md:gap-2 p-2 md:p-3">
        {services.map((svc) => (
          <a
            href="/services"
            class="service-card flex-1 min-w-[calc(50%-4px)] md:min-w-0 rounded-xl md:rounded-2xl p-3 md:p-5 flex flex-col justify-between text-left transition-all duration-300 hover:scale-[1.02]"
            aria-label={`View details of ${svc.name.replace('\n', ' ')}`}
          >
            <h3 class={`text-xl md:text-4xl font-bold leading-[1.05] whitespace-pre-line ${
              svc.active ? 'text-black' : 'text-white'
            }`}>
              {svc.name}
            </h3>

            {svc.num ? (
              <span class={`self-end w-8 h-8 md:w-12 md:h-12 rounded-full border flex items-center justify-center text-xs md:text-sm font-semibold ${
                svc.active ? 'border-black text-black' : 'border-white text-white'
              }`}>
                {svc.num}
              </span>
            ) : (
              <span class={`self-end w-8 h-8 md:w-12 md:h-12 rounded-full border flex items-center justify-center text-xs md:text-sm font-semibold ${
                svc.active ? 'border-black text-black' : 'border-white text-white'
              }`}>
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" class="rotate-[-45deg]">
                  <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            )}
          </a>
        ))}
      </div>
    </div>

  </div>
</section>