---
import Drawer from "./Drawer.astro";
---

<div class="drawers-collection select-none">
  <!-- BOOKING DRAWER -->
  <Drawer id="booking" title="Book Appointment">
    <div class="h-full flex flex-col justify-between">
      <!-- FORM CONTAINER -->
      <form id="booking-form" class="space-y-5 select-text">
        <p class="text-xs text-neutral-500 leading-relaxed mb-4 font-semibold">
          Complete the form below to request an appointment. Our staff will
          manually call you to confirm your exact time slot.
        </p>

        <!-- Name -->
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 mb-1"
            for="book-name">Full Name <span class="text-red-500">*</span></label
          >
          <input
            type="text"
            id="book-name"
            name="name"
            required
            class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
            placeholder="John Doe"
          />
          <p class="error-msg text-red-500 text-xs mt-1 hidden" id="error-name">
            Name is required.
          </p>
        </div>

        <!-- Phone -->
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 mb-1"
            for="book-phone"
            >Phone Number <span class="text-red-500">*</span></label
          >
          <input
            type="tel"
            id="book-phone"
            name="phone"
            required
            class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
            placeholder="+1 (555) 0123"
          />
          <p
            class="error-msg text-red-500 text-xs mt-1 hidden"
            id="error-phone"
          >
            Provide a valid phone number (minimum 8 digits).
          </p>
        </div>

        <!-- Email -->
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 mb-1"
            for="book-email"
            >Email Address <span class="text-red-500">*</span></label
          >
          <input
            type="email"
            id="book-email"
            name="email"
            required
            class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
            placeholder="johndoe@example.com"
          />
          <p
            class="error-msg text-red-500 text-xs mt-1 hidden"
            id="error-email"
          >
            Provide a valid email address.
          </p>
        </div>

        <!-- Service -->
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 mb-1"
            for="book-service"
            >Select Service <span class="text-red-500">*</span></label
          >
          <select
            id="book-service"
            name="service"
            required
            class="w-full px-4 py-2.5 border border-neutral-200 bg-white rounded-lg text-sm text-black focus:outline-none focus:border-black"
          >
            <option value="">-- Choose a Service --</option>
            <option value="Porcelain Veneers">Porcelain Veneers</option>
            <option value="Dental Crowns & Bridges"
              >Dental Crowns & Bridges</option
            >
            <option value="Teeth Whitening">Teeth Whitening</option>
            <option value="Dental Implants">Dental Implants</option>
            <option value="Teeth Cleaning & Hygiene"
              >Teeth Cleaning & Hygiene</option
            >
            <option value="Root Canal Therapy">Root Canal Therapy</option>
          </select>
          <p
            class="error-msg text-red-500 text-xs mt-1 hidden"
            id="error-service"
          >
            Please select a service.
          </p>
        </div>

        <!-- Date & Time -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label
              class="block text-xs font-semibold text-neutral-500 mb-1"
              for="book-date"
              >Preferred Date <span class="text-red-500">*</span></label
            >
            <input
              type="date"
              id="book-date"
              name="date"
              required
              class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white"
            />
            <p
              class="error-msg text-red-500 text-xs mt-1 hidden"
              id="error-date"
            >
              Date must be in the future.
            </p>
          </div>
          <div>
            <label
              class="block text-xs font-semibold text-neutral-500 mb-1"
              for="book-time"
              >Preferred Time <span class="text-red-500">*</span></label
            >
            <select
              id="book-time"
              name="time"
              required
              class="w-full px-4 py-2.5 border border-neutral-200 bg-white rounded-lg text-sm text-black focus:outline-none focus:border-black"
            >
              <option value="">-- Choose Time --</option>
              <option value="09:00 AM">09:00 AM</option>
              <option value="10:00 AM">10:00 AM</option>
              <option value="11:00 AM">11:00 AM</option>
              <option value="01:00 PM">01:00 PM</option>
              <option value="02:00 PM">02:00 PM</option>
              <option value="03:00 PM">03:00 PM</option>
              <option value="04:00 PM">04:00 PM</option>
              <option value="05:00 PM">05:00 PM</option>
            </select>
            <p
              class="error-msg text-red-500 text-xs mt-1 hidden"
              id="error-time"
            >
              Please select a preferred time slot.
            </p>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label
            class="block text-xs font-semibold text-neutral-500 mb-1"
            for="book-notes">Optional Notes</label
          >
          <textarea
            id="book-notes"
            name="notes"
            rows="3"
            class="w-full px-4 py-2.5 border border-neutral-200 rounded-lg text-sm text-black focus:outline-none focus:border-black bg-white resize-none"
            placeholder="Any medical histories, symptoms, or requests..."
          ></textarea>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          id="book-submit-btn"
          class="w-full py-4 bg-black text-white text-xs font-bold rounded-lg hover:bg-neutral-800 transition-colors flex items-center justify-center gap-2 cursor-pointer shadow-md"
        >
          <span id="submit-btn-text">Submit Booking Request</span>
          <svg
            id="submit-btn-spinner"
            class="animate-spin h-4 w-4 text-white hidden"
            viewBox="0 0 24 24"
            fill="none"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
            ></path>
          </svg>
        </button>

        <p
          id="form-error-summary"
          class="hidden text-red-500 text-xs text-center font-bold"
        >
          Unable to process appointment. Please correct form fields.
        </p>
      </form>

      <!-- SUCCESS SCREEN -->
      <div
        id="booking-success"
        class="hidden h-full flex flex-col justify-between py-6 select-text"
      >
        <div class="text-center space-y-4">
          <div
            class="w-16 h-16 bg-green-50 border border-green-200 rounded-full flex items-center justify-center mx-auto"
          >
            <span class="text-3xl text-green-600 font-bold">✓</span>
          </div>
          <h3 class="text-2xl font-extrabold text-black">
            Booking Request Sent!
          </h3>
          <p class="text-sm text-neutral-600 leading-relaxed px-4">
            Thank you for choosing us. We have received your booking details and
            will contact you shortly to confirm your slot.
          </p>

          <!-- Appointment Summary Card -->
          <div
            class="bg-neutral-50 border border-neutral-100 p-5 rounded-2xl text-left text-xs space-y-2 mt-6 max-w-sm mx-auto shadow-sm"
          >
            <h4
              class="text-xs font-extrabold text-black uppercase tracking-wider border-b border-neutral-200/50 pb-2 mb-3"
            >
              Appointment Summary
            </h4>
            <div class="flex justify-between">
              <span class="text-neutral-400 font-semibold">Patient:</span>
              <span class="font-bold text-black" id="summary-name">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-neutral-400 font-semibold">Service:</span>
              <span class="font-bold text-black" id="summary-service">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-neutral-400 font-semibold">Date:</span>
              <span class="font-bold text-black" id="summary-date">-</span>
            </div>
            <div class="flex justify-between">
              <span class="text-neutral-400 font-semibold">Time Slot:</span>
              <span class="font-bold text-black" id="summary-time">-</span>
            </div>
          </div>
        </div>

        <div class="space-y-3 pt-6 border-t border-neutral-100 mt-8">
          <!-- Download Transcript PDF Button -->
          <button
            id="download-pdf-btn"
            class="w-full py-4 bg-black text-white text-xs font-bold rounded-lg hover:bg-neutral-800 transition-colors flex items-center justify-center gap-2 cursor-pointer shadow-md"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            <span>Download PDF Transcript</span>
          </button>

          <!-- Return Home Trigger -->
          <button
            id="return-home-btn"
            class="w-full py-3.5 bg-neutral-100 text-black text-xs font-bold rounded-lg hover:bg-neutral-200 transition-colors cursor-pointer text-center block"
          >
            Back to Website
          </button>
        </div>
      </div>
    </div>
  </Drawer>
</div>
