---
interface Props {
  id: string;
  title: string;
  widthClass?: string;
}

const {
  id,
  title,
  widthClass = "w-[90%] md:w-[600px] max-w-2xl",
} = Astro.props;
---

<div
  id={id}
  class="drawer-container fixed inset-0 z-50 pointer-events-none select-none"
  role="dialog"
  aria-modal="true"
>
  <div
    class="drawer-backdrop absolute inset-0 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500 ease-[cubic-bezier(0.76,0,0.24,1)]"
  >
  </div>
  <div
    class={`drawer-panel absolute top-0 right-0 h-full ${widthClass} bg-white shadow-2xl translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] flex flex-col`}
  >
    <div
      class="px-6 py-5 border-b border-neutral-100 flex items-center justify-between shrink-0"
    >
      <h2 class="text-2xl font-bold text-black select-text">{title}</h2>
      <button
        class="drawer-close w-10 h-10 rounded-full border border-neutral-200 flex items-center justify-center text-black hover:bg-black hover:text-white transition-colors cursor-pointer"
        aria-label="Close Details"
      >
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
          <path
            d="M1 1l12 12M13 1L1 13"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
    <div
      class="drawer-body flex-1 overflow-y-auto custom-scrollbar p-6 md:p-8 select-text"
    >
      <slot />
    </div>
  </div>
</div>

<script>
  function setupDrawer(drawerContainer: HTMLElement) {
    // GUARD: skip if already initialized
    if (drawerContainer.dataset.drawerReady === "true") return;
    drawerContainer.dataset.drawerReady = "true";

    const backdrop = drawerContainer.querySelector(".drawer-backdrop");
    const panel = drawerContainer.querySelector(".drawer-panel");
    const closeBtn = drawerContainer.querySelector(".drawer-close");

    function openDrawer() {
      drawerContainer.classList.remove("pointer-events-none");
      drawerContainer.classList.add("pointer-events-auto");
      backdrop?.classList.remove("opacity-0", "pointer-events-none");
      backdrop?.classList.add("opacity-100", "pointer-events-auto");
      panel?.classList.remove("translate-x-full");
      panel?.classList.add("translate-x-0");
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      panel?.classList.add("translate-x-full");
      panel?.classList.remove("translate-x-0");
      backdrop?.classList.remove("opacity-100");
      backdrop?.classList.add("opacity-0");
      setTimeout(() => {
        if (panel?.classList.contains("translate-x-full")) {
          drawerContainer.classList.add("pointer-events-none");
          drawerContainer.classList.remove("pointer-events-auto");
          backdrop?.classList.add("pointer-events-none");
          backdrop?.classList.remove("pointer-events-auto");
          const openDrawers = document.querySelectorAll(
            ".drawer-container:not(.pointer-events-none)",
          );
          if (openDrawers.length === 0) {
            document.body.style.overflow = "";
          }
        }
      }, 500);
    }

    closeBtn?.addEventListener("click", closeDrawer);
    backdrop?.addEventListener("click", closeDrawer);

    // Use AbortController so listeners are cleaned up on page transitions
    const ac = new AbortController();

    document.addEventListener(
      "open-drawer",
      (e: any) => {
        if (e.detail?.target === drawerContainer.id) openDrawer();
      },
      { signal: ac.signal },
    );

    document.addEventListener(
      "close-drawer",
      (e: any) => {
        if (
          e.detail?.target === drawerContainer.id ||
          e.detail?.target === "all"
        )
          closeDrawer();
      },
      { signal: ac.signal },
    );

    // Clean up listeners when Astro navigates away
    document.addEventListener("astro:before-swap", () => ac.abort(), {
      once: true,
    });
  }

  function initAllDrawers() {
    document.querySelectorAll(".drawer-container").forEach((drawer) => {
      setupDrawer(drawer as HTMLElement);
    });
  }

  initAllDrawers();
  document.addEventListener("astro:page-load", initAllDrawers);
</script>
