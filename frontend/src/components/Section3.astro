---
interface Props {
  client?: {
    section3_img1?: string;
    section3_img2?: string;
    section3_bg?: string;
  };
}

const { client } = Astro.props;

const SECTION3_IMG1 =
  client?.section3_img1 ??
  "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_115253_c19ab167-8dd5-48b4-967d-b9f0d9d6e8fb.png&w=1280&q=85";
const SECTION3_IMG2 =
  client?.section3_img2 ??
  "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_115237_fc519057-6e87-4abf-999a-9610b8b085b4.png&w=1280&q=85";
const SECTION3_BG =
  client?.section3_bg ??
  "https://images.higgs.ai/?default=1&output=webp&url=https%3A%2F%2Fd8j0ntlcm91z4.cloudfront.net%2Fuser_38xzZboKViGWJOttwIXH07lWA1P%2Fhf_20260624_114355_752ba9e6-0942-4abb-9047-5d9bb16632e9.png&w=1280&q=85";
---

<section
  id="about"
  class="reveal-container min-h-screen md:h-screen w-full overflow-hidden flex flex-col pt-1.5 md:pt-2 px-3 md:px-5 pb-1.5 md:pb-2 gap-1.5 md:gap-2 select-none bg-white"
>
  <div class="flex-1 min-h-0 grid grid-cols-1 md:grid-cols-2 gap-1.5 md:gap-2">

    <!-- LEFT COLUMN -->
    <div class="flex flex-col gap-1.5 md:gap-2 h-full">

      <!-- 1. Heading Card -->
      <div class="reveal-item rounded-xl md:rounded-2xl bg-stone-50 p-5 md:p-7 flex flex-col justify-between flex-[1.2] min-h-[180px] md:min-h-0 transition-all duration-300">
        <p class="text-xs md:text-sm font-semibold text-black uppercase tracking-wider">
          Restore Missing Teeth
        </p>
        <h2 class="text-[clamp(2.5rem,7vw,6.5rem)] font-bold leading-[0.95] text-black">
          Implant<br />Dentistry
        </h2>
      </div>

      <!-- 2. Two Image Cards -->
      <div class="reveal-item flex gap-1.5 md:gap-2 flex-1 min-h-[140px] md:min-h-0">
        <div class="flex-1 rounded-xl md:rounded-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-300">
          <img
            src={SECTION3_IMG1}
            alt="Dental implant installation setup close-up"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="flex-1 rounded-xl md:rounded-2xl overflow-hidden hover:scale-[1.01] transition-transform duration-300">
          <img
            src={SECTION3_IMG2}
            alt="Dental restoration process visual"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- 3. Consultation Card -->
      <div class="reveal-item rounded-xl md:rounded-2xl bg-zinc-200 p-4 md:p-7 flex items-center justify-between min-h-[140px] md:min-h-[180px] hover:bg-zinc-300 transition-colors duration-300">
        <div class="flex flex-col justify-between h-full items-start">
          <p class="text-xs md:text-sm font-semibold text-black uppercase tracking-wider mb-2 md:mb-3">
            Consultation
          </p>
          <h3 class="text-xl md:text-3xl font-bold text-black leading-6 md:leading-8 whitespace-pre-line pb-10">
            Dental Restoration Services
          </h3>
        </div>
        <button
          class="book-trigger px-5 py-3 md:px-8 md:py-5 bg-white text-black text-base md:text-xl font-bold rounded-full hover:scale-105 transition-transform duration-200 shadow-md cursor-pointer"
          aria-label="Book Consultation Online"
        >
          Book Online
        </button>
      </div>
    </div>

    <!-- RIGHT COLUMN: Tall image card -->
    <div class="reveal-item rounded-xl md:rounded-2xl overflow-hidden relative min-h-[350px] md:min-h-0">
      <img
        src={SECTION3_BG}
        alt="Smiling patient showing results of professional dental work"
        class="w-full h-full object-cover absolute inset-0"
        loading="lazy"
      />

      <!-- Overlay cards -->
      <div class="absolute bottom-3 left-3 right-3 md:bottom-5 md:left-5 md:right-5 flex gap-1.5 md:gap-2 z-10">
        <a
          href="/services"
          class="process-card flex-1 bg-white rounded-xl md:rounded-2xl p-3 md:p-5 flex flex-col justify-between h-36 md:h-52 text-left hover:scale-[1.02] transition-transform duration-300"
          aria-label="Learn about the process of installing implants"
        >
          <h4 class="text-lg md:text-2xl font-bold text-black leading-5 md:leading-7">
            The Process<br />of Installing<br />Implants
          </h4>
          <span class="self-end w-9 h-9 md:w-12 md:h-12 rounded-full border border-black flex items-center justify-center text-black">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="rotate-[-45deg]">
              <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>

        <a
          href="/services"
          class="process-card flex-1 bg-white/20 backdrop-blur-xl rounded-xl md:rounded-2xl p-3 md:p-5 flex flex-col justify-between h-36 md:h-52 text-left hover:bg-white/30 hover:scale-[1.02] transition-all duration-300"
          aria-label="Learn about caring for dental implants"
        >
          <h4 class="text-lg md:text-2xl font-bold text-white leading-5 md:leading-7">
            Caring<br />for Dental<br />Implants
          </h4>
          <span class="self-end w-9 h-9 md:w-12 md:h-12 rounded-full border border-white flex items-center justify-center text-white">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="rotate-[-45deg]">
              <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>
    </div>

  </div>
</section>